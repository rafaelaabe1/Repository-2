        "# Regras\n",
        "\n",
        "# Utilizar while\n",
        "# Definir uma variavel para o bimestre e uma variavel para nota e uma variavel para o resultado.\n",
        "\n",
        "nota = 0\n",
        "resultado = 0\n",
        "bimestre = 1\n",
        "\n",
        "while bimestre <= 4:\n",
        "  nota = float(input(f\"digite sua nota do {bimestre}º bimestre: \"))\n",
        "  bimestre +=1\n",
        "  resultado = resultado+nota\n",
        "print(f\"sua media é: {resultado}\")\n",
        "\n",
        "media = resultado / 4\n",
        "\n",
        "if media >= 7:\n",
        "  print(f\"Sua nota final foi {resultado}, você esta Aprovado\")\n",
        "\n",
        "elif media >= 5:\n",
        "  print(f\"Sua nota final foi {resultado}, você esta de Recuperação\")\n",
        "\n",
        "else:\n",
        "  print(f\"Sua nota final foi {resultado}, você esta Reprovado\")"
